            "user_prompt": {
                "name": "Aviso de usuario",
                "tooltip": "Su mensaje para ser mejorado"
            },
            "llm_service": {
                "name": "Servicio de Maestría en Derecho",
                "tooltip": "Seleccione el servicio LLM"
