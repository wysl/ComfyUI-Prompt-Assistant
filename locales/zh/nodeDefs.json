{
    "PromptExpand": {
        "display_name": "✨提示词优化",
        "description": "使用LLM增强或扩写您的提示词",
        "inputs": {
            "rule": {
                "name": "规则预设",
                "tooltip": "选择提示词优化的预设规则"
            },
            "custom_rule": {
                "name": "自定义规则",
                "tooltip": "启用下方自定义规则输入"
            },
            "custom_rule_content": {
                "name": "自定义规则内容",
                "tooltip": "在此输入您的自定义规则内容"
            },
            "user_prompt": {
                "name": "用户提示词",
                "tooltip": "想要增强的原始提示词"
            },
            "llm_service": {
                "name": "LLM服务",
                "tooltip": "选择LLM服务和模型"
            },
            "ollama_auto_unload": {
                "name": "自动释放显存",
                "tooltip": "生成完成后自动释放Ollama模型显存"
            },
            "source_text": {
                "name": "原文输入",
                "tooltip": "可选的输入文本"
            },
            "seed": {
                "name": "随机种子",
                "tooltip": "控制生成的随机性。选择非固定模式可强制节点重新执行"
            }
        },
        "outputs": {
            "0": {
                "name": "提示词输出",
                "tooltip": "增强后的提示词结果"
            }
        }
    },
